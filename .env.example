# ─── Local Development Database ──────────────────────────────────────────────
# Copy this file to .env and fill in your local values.
# .env is gitignored — never commit it.

# Option A: use the standard DATABASE_URL key
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/colombo

# Option B: use the project-specific key (takes priority over DATABASE_URL)
# COLOMBO_DB_URL=postgresql://postgres:yourpassword@localhost:5432/colombo
