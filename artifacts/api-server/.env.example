# ─── Server Ports ───────────────────────────────────────────────────────────
# Main REST API port
PORT=3000

# ADMS / ZKTeco Push server port
ADMS_PORT=3333

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
COLOMBO_DB_URL=postgresql://postgres:PASSWORD@HOST:5432/DATABASE

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
